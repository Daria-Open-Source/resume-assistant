{
  "name": "resume-assistant",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "format": "prettier --write \"client/src/**/*.{ts,tsx}\" \"server/src/**/*.js\"",
    "format:check": "prettier --check \"client/src/**/*.{ts,tsx}\" \"server/src/**/*.js\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "client/src/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "server/src/**/*.js": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  }
}
